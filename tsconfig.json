{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",

    "target": "ES2021",
    "rootDir": "./src",
    "outDir": "./dist",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "strict": true,
    "skipLibCheck": true,

    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"]
    },

    "types": ["node", "jest"]
  },
  "exclude": ["node_modules", "dist"]
}