{
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node10",
        "target": "es2021",
        "rootDir": "./src",
        "outDir": "./dist",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "strict": true,
        "skipLibCheck": true,
        "types": [
            "node",
            "jest"
